# 1. Скопируйте в application-local.yml (файл в .gitignore — не коммитьте секреты).
# 2. Запуск с профилем local:
#    ./mvnw spring-boot:run -Dspring-boot.run.arguments="--spring.profiles.active=local"

spring:
  config:
    activate:
      on-profile: local
  datasource:
    url: jdbc:postgresql://localhost:5432/library
    username: postgres
    password: ${LIBRARY_DB_PASSWORD:your_password_here}
  jpa:
    show-sql: true

# Для приветственного письма читателю со ссылкой на пароль:
# library:
#   app:
#     public-base-url: "http://localhost:8080"
#   mail:
#     welcome-reader:
#       enabled: true
# spring:
#   mail:
#     host: …
